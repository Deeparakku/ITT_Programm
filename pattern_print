# 1. Define how many rows you want to print
rows = 3

# 2. Start the outer loop for the rows
for i in range(1, rows + 1):
    
    # Phase 1: Count UP (Cursor stays on this line)
    for j in range(1, i + 1):
        print(j, end="") 
        
    # Phase 2: Count DOWN (Cursor STILL stays on this line)
    for j in range(i - 1, 0, -1):
        print(j, end="") 
        
    # Move the cursor to a brand new line for the next row
    print()
